{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "neural-seam hook session-start" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          { "type": "command", "command": "neural-seam hook pre-tool-use" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "neural-seam hook stop", "timeout": 5000 }
        ]
      }
    ]
  }
}
